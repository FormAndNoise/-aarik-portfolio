---
// src/components/WorkGallery.astro

const projects = [
  {
    title: "MiniBook Suite",
    description: "A dual-LLM pipeline that turns a single idea into a finished, illustrated, character-consistent storybook — automatically.",
    tags: ["ComfyUI", "SDXL", "LLM Orchestration"],
    link: "/projects/minibook",
    type: "Flagship Project"
  },
  {
    title: "Keratin",
    description: "A custom Model Context Protocol (MCP) bridge connecting Claude AI to Rhinoceros 3D for text-to-parametric design.",
    tags: ["Python", "Rhino 7", "MCP"],
    link: "/projects/keratin",
    type: "Utility & Exploration"
  },
  {
    title: "Lineforge",
    description: "A self-contained Windows batch image processing pipeline using a custom AI-directed Rust backend for vector tracing.",
    tags: ["Python", "Rust", "Computer Vision"],
    link: "/projects/lineforge",
    type: "Utility & Exploration"
  },
  {
    title: "Metalsmith LoRA",
    description: "A micro-dataset FLUX LoRA trained on photos of a bespoke physical ring to rapidly prototype new jewelry designs.",
    tags: ["FLUX", "LoRA", "Product Design", "Dataset Curation"],
    link: "/projects/metalsmith-lora",
    type: "Utility & Exploration"
  }
];
---

<section id="work" class="work-gallery">
  <div class="wg-header">
    <h2>Featured Work</h2>
    <p>Systems, pipelines, and utilities built through AI-assisted development.</p>
  </div>

  <div class="wg-grid">
    {projects.map((p) => (
      <a href={p.link} class={`wg-card ${p.type === 'Flagship Project' ? 'wg-card--featured' : ''}`}>
        <div class="wg-card__meta">{p.type}</div>
        <h3 class="wg-card__title">{p.title}</h3>
        <p class="wg-card__desc">{p.description}</p>
        <ul class="wg-card__tags">
          {p.tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      </a>
    ))}
  </div>
</section>

<style>
  .work-gallery {
    padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 5vw, 4rem);
    background: #08080A;
    color: var(--text, #EDEDEF);
    font-family: var(--font-body, "Inter", system-ui, sans-serif);
  }

  .wg-header {
    margin-bottom: 3rem;
  }
  
  .wg-header h2 {
    font-family: var(--font-display, "Space Grotesk", system-ui, sans-serif);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
  }
  
  .wg-header p {
    color: var(--muted, #6B7B8D);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0;
  }

  .wg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .wg-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background: #111114;
    border: 1px solid #202026;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  
  .wg-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent, #D4A853);
  }

  .wg-card--featured {
    grid-column: 1 / -1;
    background: linear-gradient(145deg, #15151A 0%, #0F0F13 100%);
    border-color: #2A2A33;
  }
  
  .wg-card--featured:hover {
    border-color: var(--accent, #D4A853);
  }

  .wg-card__meta {
    font-family: var(--font-mono, "JetBrains Mono", monospace);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent, #D4A853);
    margin-bottom: 1rem;
  }

  .wg-card__title {
    font-family: var(--font-display, "Space Grotesk", system-ui, sans-serif);
    font-size: 1.5rem;
    margin: 0 0 1rem;
  }
  
  .wg-card--featured .wg-card__title {
    font-size: 2.2rem;
  }

  .wg-card__desc {
    color: #A0A2A8;
    line-height: 1.6;
    margin: 0 0 2rem;
    flex-grow: 1;
  }

  .wg-card__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .wg-card__tags li {
    font-family: var(--font-mono, "JetBrains Mono", monospace);
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    color: #C7C9CE;
  }
</style>
