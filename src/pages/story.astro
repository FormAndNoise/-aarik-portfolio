    --font-display: "Space Grotesk", system-ui, sans-serif;
    
    max-width: 700px;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem);
    color: var(--text);
  }

  .story-content h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    margin-bottom: 2rem;
    color: var(--accent);
  }

  .story-section {
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  .story-section h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .story-section p {
    margin-bottom: 1rem;
    color: #C7C9CE;
  }

  .story-section p strong {
    color: var(--text);
  }

