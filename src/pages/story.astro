  }

  .cs-cta {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #2A2A30;
  }

  .cs-cta p {
    margin-bottom: 0.5rem;
  }

  .cs-cta a {
    color: var(--accent);
